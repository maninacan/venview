<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="images/favicon.ico">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>venOS Event Manager - Dashboard</title>
  <meta name="description" content="Manage your events, track expenses, and see real profit with venOS's event dashboard.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="venOS Event Manager">
  <meta property="og:description" content="Manage your events, track expenses, and see real profit with venOS's event dashboard.">
  <meta property="og:image" content="/images/logo.png">
  <meta property="og:url" content="https://venview.fly.dev/app.html">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="stylesheet" href="styles.css">
  <style>
    /* ── Dashboard header layout ─────────────────────────── */
    .dashboard-title-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .event-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--vv-navy, #1a2e4a);
    }
    .event-date {
      font-size: 0.9rem;
      color: #64748b;
      font-weight: 500;
    }

    /* ── Button rows ─────────────────────────────────────── */
    .dashboard-buttons {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 20px;
    }
    .dash-btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    /* Subtle visual separator between rows */
    .dash-btn-row--secondary {
      padding-top: 4px;
    }
    .dash-btn-row--danger {
      padding-top: 8px;
      border-top: 1px solid #f1f5f9;
      margin-top: 2px;
    }

    /* Subdued danger button — outline only, fills red on hover */
    .btn-danger-subtle {
      background: transparent;
      color: #dc2626;
      border: 1px solid #fca5a5;
      border-radius: 8px;
      padding: 7px 14px;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .btn-danger-subtle:hover {
      background: #dc2626;
      color: #fff;
      border-color: #dc2626;
    }

    /* Labor card: Pull Square Labor sits to the right */
    .labor-square-btn {
      margin-left: auto;
      font-size: 0.82rem;
    }

    /* Finalized badge in title row */
    .finalized-badge-large {
      display: inline-block;
      background: #dcfce7;
      color: #15803d;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 99px;
      border: 1px solid #bbf7d0;
    }
    .finalized-date-label {
      font-size: 0.78rem;
      color: #64748b;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
</head>
<body>
	<div class="app-shell">
  <header>
    <div class="brand">
      <img src="images/venview-icon-lg.png" alt="venOS" class="brand-logo">
      <div class="brand-text">
        <span class="brand-title">venOS Events</span>
        <span class="brand-subtitle">Vendor Intelligence for Events</span>
      </div>
    </div>
    <div class="nav-buttons">
      <button class="hamburger" onclick="toggleMobileNav()" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="header-buttons" id="headerButtonsDrawer">
        <button id="btnHome"      class="nav-link" onclick="closeMobileNav(); window.location.href='/'">Home</button>
        <button id="btnCompany"   class="nav-link" onclick="closeMobileNav(); navigateTo('companySection')">Register Company</button>
        <button id="btnManage"    class="nav-link" onclick="closeMobileNav(); navigateTo('manageSection')">Manage Events</button>
        <button id="btnInventory" class="nav-link" style="display:none" onclick="closeMobileNav(); navigateTo('inventorySection')">My Inventory</button>
        <button id="btnRestock"   class="nav-link" style="display:none" onclick="closeMobileNav(); navigateTo('restockSection')">🔄 Restock</button>
        <button id="btnRecipes"   class="nav-link" onclick="closeMobileNav(); navigateTo('recipesSection')">Recipes</button>
        <button id="btnSettings"  class="nav-link" onclick="closeMobileNav(); navigateTo('settingsSection')">Settings</button>
        <button id="btnAdmin"     class="nav-link hidden" onclick="closeMobileNav(); navigateTo('adminSection')">Admin</button>
        <button id="btnLogout"    class="nav-link" onclick="closeMobileNav(); handleLogout()">Logout</button>
        <button id="btnAdd"       class="nav-cta"  onclick="closeMobileNav(); openAddEventForUser()">+ Add Event</button>
      </div>
      <!-- 🔔 Reorder Alerts Bell — far-right utility icon -->
      <button id="btnAlerts" class="alerts-bell hidden" onclick="toggleAlertsPanel()" aria-label="Reorder alerts">
        🔔
        <span id="alertsBadge" class="alerts-badge hidden">0</span>
      </button>
    </div>
  </header>

  <!-- 🔔 Alerts Panel (Pro) -->
  <div id="alertsPanel" class="alerts-panel hidden">
    <div class="alerts-panel-header">
      <strong>Reorder Alerts</strong>
      <button class="alerts-mark-all" onclick="markAllAlertsRead()">Mark all read</button>
      <button class="alerts-close" onclick="toggleAlertsPanel()">✕</button>
    </div>
    <div id="alertsPanelList" class="alerts-panel-list">
      <p class="alerts-empty">No reorder alerts.</p>
    </div>
  </div>

  <!-- 🔐 Auth Section -->
  <section id="authSection" class="card">
    <div class="auth-container">
      <div class="auth-brand">
        <span class="brand-title">venOS Events</span>
        <span class="brand-subtitle">Vendor Intelligence for Events</span>
      </div>
      <h2 id="authTitle">Sign In</h2>
      <p id="authSubtitle" class="auth-subtitle">Welcome back! Sign in to manage your events.</p>
      <form id="authForm" onsubmit="handleAuth(event)">
        <div class="auth-fields">
          <input type="email" id="authEmail" placeholder="Email address" required>
          <input type="password" id="authPassword" placeholder="Password" required>
        </div>
        <div id="authError" class="auth-error"></div>
        <button type="submit" class="btn-primary auth-submit" id="authSubmitBtn">Sign In</button>
      </form>
      <p class="auth-toggle">
        <span id="authToggleText">Don't have an account?</span>
        <a href="#" id="authToggleLink" onclick="toggleAuthMode(event)">Sign Up</a>
      </p>
      <p class="auth-toggle" id="forgotPasswordRow">
        <a href="#" onclick="showForgotPassword(event)" style="font-size:0.85em;color:var(--text-muted,#888);">Forgot Password?</a>
      </p>
    </div>
  </section>

  <!-- 🔑 Forgot Password Modal -->
  <div id="forgotPasswordModal" class="modal-overlay hidden" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="modal-box" style="max-width:400px">
      <h3 style="margin-top:0">Reset Password</h3>
      <p style="font-size:0.9em;color:var(--text-muted,#666)">Enter your email and we'll send a reset link.</p>
      <form id="forgotPasswordForm" onsubmit="sendPasswordReset(event)">
        <input type="email" id="resetEmail" placeholder="Email address" required style="width:100%;margin-bottom:10px;padding:8px;box-sizing:border-box;">
        <div id="resetError" style="color:#c0392b;font-size:0.85em;margin-bottom:8px;"></div>
        <div id="resetSuccess" style="color:#27ae60;font-size:0.9em;margin-bottom:8px;display:none;"></div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button type="button" class="btn-secondary" onclick="document.getElementById('forgotPasswordModal').classList.add('hidden')">Cancel</button>
          <button type="submit" class="btn-primary" id="resetSubmitBtn">Send Reset Link</button>
        </div>
      </form>
    </div>
  </div>

  <!-- 🔑 Set New Password Modal (shown after clicking reset link in email) -->
  <div id="setNewPasswordModal" class="modal-overlay hidden">
    <div class="modal-box" style="max-width:400px">
      <h3 style="margin-top:0">Set New Password</h3>
      <p style="font-size:0.9em;color:var(--text-muted,#666)">Choose a new password for your account.</p>
      <form id="setNewPasswordForm" onsubmit="handleSetNewPassword(event)">
        <input type="password" id="newPassword" placeholder="New password" required minlength="8" style="width:100%;margin-bottom:10px;padding:8px;box-sizing:border-box;">
        <input type="password" id="confirmNewPassword" placeholder="Confirm new password" required minlength="8" style="width:100%;margin-bottom:10px;padding:8px;box-sizing:border-box;">
        <div id="setPasswordError" style="color:#c0392b;font-size:0.85em;margin-bottom:8px;"></div>
        <button type="submit" class="btn-primary" style="width:100%">Update Password</button>
      </form>
    </div>
  </div>

  <!-- ⚙️ Settings Section -->
  <section id="settingsSection" class="hidden">

    <!-- Post-OAuth return banner -->
    <div id="returnBanner" class="sq-return-banner hidden">
      <span style="font-size:20px;">✅</span>
      <p><strong>Square connected successfully!</strong> Your locations are now available — link one when adding your next event.</p>
    </div>

    <!-- Onboarding banner (new / disconnected users) -->
    <div id="onboardingBanner" class="card sq-onboarding-banner hidden">
      <div class="sq-banner-icon">🔗</div>
      <div class="sq-banner-body">
        <strong>Connect Square to unlock automatic syncing</strong>
        <p>Connect your Square account to automatically sync sales, locations, and labor from your events.</p>
        <div class="sq-banner-actions">
          <button class="sq-btn-banner" onclick="startSquareOAuth()">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="0.5" y="0.5" width="5" height="5" rx="0.8" fill="white"/><rect x="7.5" y="0.5" width="5" height="5" rx="0.8" fill="white"/><rect x="0.5" y="7.5" width="5" height="5" rx="0.8" fill="white"/><rect x="7.5" y="7.5" width="5" height="5" rx="0.8" fill="white"/></svg>
            Connect Square
          </button>
          <button class="sq-btn-banner-dismiss" onclick="dismissSquareBanner()">I'll do this later</button>
        </div>
      </div>
      <button class="sq-banner-close" onclick="dismissSquareBanner()" aria-label="Dismiss">✕</button>
    </div>

    <!-- Integrations card -->
    <div class="card">
      <div class="sq-page-header">
        <h2>Settings</h2>
        <p>Manage your account and integrations</p>
      </div>

      <p class="sq-section-label">Integrations</p>
      <p style="font-size:0.85rem; color:var(--muted); margin-bottom:14px;">
        Connect third-party services to automate your data.
      </p>

      <div class="sq-integration-item">
        <div class="sq-integration-header">
          <div class="sq-logo">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <rect x="2.5" y="2.5" width="21" height="21" rx="3.5" fill="white"/>
              <rect x="7" y="7" width="12" height="12" rx="2" fill="black"/>
            </svg>
          </div>
          <div class="sq-integration-meta">
            <h3>Square POS</h3>
            <p>Sync sales, locations &amp; labor automatically</p>
          </div>
          <span id="squareBadge" class="sq-badge sq-badge-off">Not Connected</span>
        </div>
        <div class="sq-integration-body" id="squareBody"></div>
      </div>
    </div>

    <!-- Team / Org card -->
    <div class="card" style="margin-top:18px;">
      <p class="sq-section-label" style="margin-bottom:6px;">Team Access</p>
      <p style="font-size:0.85rem; color:var(--muted); margin-bottom:16px;">
        Share your events, inventory, and recipes with your team. Everyone in the same organization sees the same data.
      </p>
      <div id="orgPanel">
        <p style="color:var(--muted);font-size:0.85rem;">Loading…</p>
      </div>
    </div>

  </section><!-- /settingsSection -->

  <!-- ➕ Add Event Section -->
     <section id="addSection" class="card hidden">
      <h2 id="formTitle">Add New Event</h2>

      <div id="proAddEventFields">
    	<label for="permitFiles">Permit Documents:</label>
    	<input type="file" id="permitFiles" multiple>
    	<label>Square Location</label>
        <div id="locationPrompt" class="sq-prompt hidden">
          <div class="sq-prompt-icon">📍</div>
          <div class="sq-prompt-text">
            <strong>No Square locations found</strong>
            <p>Connect your Square account to link a location and enable automatic sales sync.</p>
            <button class="sq-btn-prompt-link" onclick="navigateTo('settingsSection')">Connect Square in Settings →</button>
          </div>
        </div>
        <select id="form_squareLocationId">
          <option value="">Select Square Location…</option>
        </select>
      </div>

      <!-- 🧩 Dynamic Form Area -->
      <form id="eventForm" onsubmit="submitEvent(event); return false;" class="event-form">
        <!-- The fields for this form will be dynamically injected here by rebuildAddEventForm() -->
      </form>
    </section>
<!-----------------------Company Section ------------------------>
    <section id="companySection" class="card hidden">
    <h2>Register Your Company</h2>
        <div class="company-fields">
          <input type="text" id="companyName" placeholder="CompanyName">
          <input type="text" id="phone" placeholder="Phone">
    	  <input type="text" id="contactName" placeholder="ContactName">
    	  <input type="text" id="vendorCategory" placeholder="Vendor Category">
    	  <input type="text" id="email" placeholder="email">
          <button type="button" onclick="withSpinner(this, () => addCompany(event))">Submit</button>
    	  <button type="button" onclick="clearEventForm()">Clear</button>
        </div>

    </section>

<!-- 🧩 Design Event Form Section -->
    <section id="designFormSection" class="card hidden">
      <h2>🧩 Design Event Form</h2>
    	<!-- 🧩 Template Activation Controls -->
      <div class="template-activation">
        <label for="templateSelector"><strong>Activate Template:</strong></label>
        <select id="templateSelector">
          <option value="">-- Select Template --</option>
        </select>
        <button type="button" onclick="useSelectedTemplate()">⚡ Activate</button>
    	<p class="field-warning"><strong>NOTE: Field Name, Field Date and ZipCode are required Fields for All Templates.</strong>  </p>
      </div>

      <div class="form-builder-controls">
        <label>Field Label: <input type="text" id="builderLabel" placeholder="e.g. Event Name"></label>
        
        <label>Field Type:
          <select id="builderType">
            <option value="text">Text</option>
            <option value="number">Number</option>
            <option value="date">Date</option>
            <option value="select">Dropdown</option>
            <option value="multiselect">Multi-Select</option>
            <option value="textarea">Text Area</option>
          </select>
        </label>

        <label>Required: <input type="checkbox" id="builderRequired"></label>
        
        <label id="optionsLabel" style="display:none;">
          Options (comma separated): 
          <input type="text" id="builderOptions" placeholder="e.g. Red, Green, Blue">
        </label>

        <button type="button" onclick="addFieldToTemplate()">➕ Add Field</button>
      </div>

      <hr>

      <h3>Preview:</h3>
      <div id="formPreview" class="preview-card"></div>

      <div class="form-buttons">
        <button type="button" onclick="withSpinner(this, saveTemplate)">💾 Save Template</button>
        <button type="button" onclick="clearEventForm()">🧹 Clear</button>
      </div>
    </section>


    <!-- ⚙ Admin Section -->
    <section id="adminSection" class="card hidden">
      <div class="admin-header">
        <h2>⚙ Admin Panel</h2>
        <p class="admin-subtitle">Manage user plans and view account activity.</p>
      </div>

      <!-- Summary chips populated by JS -->
      <div id="adminStats" class="admin-stats"></div>

      <!-- Search bar -->
      <div class="admin-toolbar">
        <input type="text" id="adminSearch" placeholder="Search by email or user ID…" oninput="filterAdminUsers()">
        <select id="adminPlanFilter" onchange="filterAdminUsers()">
          <option value="">All Plans</option>
          <option value="starter">Starter</option>
          <option value="pro">Pro</option>
        </select>
        <button class="btn-secondary" onclick="withSpinner(this, loadAdminSection)">↺ Refresh</button>
      </div>

      <div id="adminTableContainer" class="admin-table-wrap">
        <p class="admin-empty">Loading users…</p>
      </div>
    </section>

    <section id="manageSection" class="card">
      <h2>Manage Events</h2>
      <div class="manage-filter-bar">
      <button class="btn-secondary" onclick="filterEvents('all')">All</button>
      <button class="btn-secondary" onclick="filterEvents('finalized')">Finalized</button>
      <button class="btn-secondary" onclick="filterEvents('notfinalized')">Not Finalized</button>
    </div>
      <div class="search-fields">
        <input type="text" id="manageSearchName" placeholder="eventName">
        <input type="date" id="manageSearchDate">
        <input type="text" id="manageSearchID" placeholder="eventID">
        <button type="button" onclick="withSpinner(this, manageSearch)">🔍 Search</button>
        <button type="button" onclick="withSpinner(this, loadAllEvents)">📋 List All</button>
    	<button type="button" class="btn-secondary" onclick="clearManageSearch()">🧹 Clear</button>
        <button type="button" class="btn-secondary" onclick="exportEventsCSV()">📥 Export CSV</button>
      </div>
      

      <div id="manageKpiRow" class="kpi-row hidden"></div>

      <div id="profitChartWrap" class="hidden" style="margin:20px 0 8px;padding:16px;background:#f9fafb;border-radius:10px;border:1px solid #e5e7eb">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
          <span style="font-weight:600;color:#374151">Net Profit per Event</span>
          <span style="font-size:.8rem;color:#9ca3af">All events · sorted by date</span>
        </div>
        <canvas id="profitChart" height="95"></canvas>
      </div>

      <div id="manageResults" class="table-container"></div>
    </section>

  

    <!-- 📦 Inventory Management Section -->
    <section id="inventorySection" class="card hidden">
      <div class="inv-header">
        <h2>📦 My Inventory</h2>
        <p class="inv-subtitle">Upload your product catalog once — then pick items directly when logging supply costs for any event.</p>
      </div>

      <div class="inv-toolbar">
        <div class="inv-upload-group">
          <label class="inv-file-label" for="inventoryCsvFile">
            Choose CSV
            <input type="file" id="inventoryCsvFile" accept=".csv" style="display:none">
          </label>
          <span id="inventoryCsvFileName" class="inv-file-name">No file chosen</span>
          <button class="btn-primary" onclick="withSpinner(this, uploadInventoryCSV)">⬆ Upload</button>
          <button class="btn-secondary" onclick="downloadInventoryTemplate()">⬇ Download Template</button>
          <button class="btn-danger" onclick="withSpinner(this, clearAllInventory)">🗑 Clear All</button>
        </div>
        <div class="inv-search-group">
          <input type="text" id="inventorySearch" placeholder="Search items…" oninput="filterInventoryTable()">
          <select id="inventoryCategoryFilter" onchange="filterInventoryTable()">
            <option value="">All Categories</option>
          </select>
        </div>
      </div>

      <div id="inventoryTableContainer" class="inv-table-wrap">
        <p class="inv-empty">No inventory items yet — upload a CSV or items will appear here.</p>
      </div>
    </section>

    <!-- 📊 End-of-Night Usage Report Modal -->
    <div class="modal-overlay" id="usageReportOverlay">
      <div class="usage-report-modal" id="usageReportModal">
        <div class="usage-report-header">
          <div>
            <h3 id="usageReportTitle">End-of-Night Usage Report</h3>
            <div id="usageReportMeta" class="usage-report-meta"></div>
          </div>
          <button class="modal-close" onclick="closeUsageReport()" aria-label="Close">✕</button>
        </div>
        <div id="usageReportBody" class="usage-report-body">
          <p class="empty-state-inline">Loading…</p>
        </div>
        <div class="usage-report-actions no-print">
          <button class="btn-secondary" onclick="copyUsageReport()">📋 Copy</button>
          <button class="btn-secondary" onclick="downloadUsageCSV()">⬇ CSV</button>
          <button class="btn-primary"   onclick="window.print()">🖨 Print</button>
        </div>
      </div>
    </div>

    <!-- 🔄 Restock List Section (phone-friendly, per-event) -->
    <section id="restockSection" class="card hidden">
      <div class="restock-header">
        <h2>🔄 Restock List</h2>
        <p class="restock-subtitle">Pick an event, then tap "Mark Restocked" after refilling each item. Restocking decrements warehouse stock.</p>
        <div class="restock-toolbar">
          <label for="restockEventPicker" style="font-weight:600;">Event:</label>
          <select id="restockEventPicker" onchange="loadRestockList()" style="flex:1;min-width:180px;"></select>
          <button class="btn-secondary" onclick="loadRestockList()">↻ Refresh</button>
          <span id="restockCount" class="restock-count"></span>
        </div>
      </div>
      <div id="restockListContainer" class="restock-list">
        <p class="inv-empty">Pick an event above to see its restock list.</p>
      </div>
    </section>

    <!-- 🛒 Inventory Picker Modal -->
    <div class="modal-overlay" id="inventoryPickerOverlay">
      <div class="inv-picker-modal">
        <div class="inv-picker-header">
          <h3>Pick Items from Inventory</h3>
          <button class="modal-close" onclick="closeInventoryPicker()" aria-label="Close">✕</button>
        </div>
        <div class="inv-picker-search">
          <input type="text" id="pickerSearch" placeholder="Search items…" oninput="filterPickerList()">
          <select id="pickerCategoryFilter" onchange="filterPickerList()">
            <option value="">All Categories</option>
          </select>
        </div>
        <div id="pickerListContainer" class="inv-picker-list"></div>
        <div class="inv-picker-footer">
          <span id="pickerSelectedCount" class="picker-count">0 items selected</span>
          <button class="btn-secondary" onclick="closeInventoryPicker()">Cancel</button>
          <button class="btn-primary" onclick="addPickedItemsToEvent()">➕ Add to Event</button>
        </div>
      </div>
    </div>

    <!-- 🍋 Recipes Section -->
    <section id="recipesSection" class="card hidden">
      <!-- content rendered by loadRecipesSection() -->
    </section>

    <section id="eventDashboardSection" class="card hidden dashboard-page">

      <!-- Dashboard Header (STATIC) -->
      <div class="dashboard-header">
        <div class="dashboard-title-row">
          <div id="dashEventName" class="event-title"></div>
        </div>
        <div id="dashEventDate" class="event-date"></div>
        <div id="dashFinalizedIndicator"></div>
        <div id="dashEventMeta" class="dashboard-meta"></div>
        <div class="dashboard-danger"></div>
      </div>

      <!-- Dashboard Cards (DYNAMIC) -->
      <div id="eventDashboardContainer"></div>

    </section>




    <section id="postEventReportSection" class="card hidden report-page">

      <h2 id="postEventTitle" class="report-title">📊 Post-Event Report</h2>

      <div class="report-controls">
          <div class="file-upload-block">
            <label for="permitFilesReport"><strong>Permit Documents:</strong></label>
            <input type="file" id="permitFilesReport" multiple>
          </div>

          <div class="report-buttons">
            <button class="btn-primary" onclick="withSpinner(this, downloadPostEventPDF)">📄 Download PDF</button>
            <button class="btn-secondary" onclick="navigateTo('manageSection')">⬅ Back to Manage Events</button>
          </div>
      </div>

      <div id="postEventReportContent" class="report-content"></div>

    </section>

  <!-- ⚡ Upgrade to Pro Modal -->
  <div class="modal-overlay" id="upgradeOverlay">
    <div class="upgrade-modal" id="upgradeModal">
      <div class="modal-header">
        <button class="modal-close" onclick="closeUpgradeModal()" aria-label="Close">✕</button>
        <div class="pro-badge">⚡ venOS Pro</div>
        <h2>Unlock the complete picture.</h2>
        <p>See every event's true profit, track trends over time, and make smarter decisions — faster.</p>
      </div>
      <div class="trigger-reason" id="triggerReason">
        <span class="reason-icon">🔒</span>
        <span id="triggerReasonText">This feature requires venOS Pro.</span>
      </div>
      <div class="modal-body">
        <p class="features-label">Everything in Pro</p>
        <ul class="feature-list">
          <li>
            <span class="feature-check fi-reports">✓</span>
            <div><strong>Post-Event Reports</strong><br><span>Full profit &amp; loss breakdown, shareable and printable</span></div>
          </li>
          <li>
            <span class="feature-check fi-events">✓</span>
            <div><strong>Unlimited finalized events</strong><br><span>Track every market, festival, and pop-up you run</span></div>
          </li>
          <li>
            <span class="feature-check fi-pdf">✓</span>
            <div><strong>PDF export</strong><br><span>Download branded reports for your records or accountant</span></div>
          </li>
          <li>
            <span class="feature-check fi-history">✓</span>
            <div><strong>Full event history</strong><br><span>Compare events over time to find your most profitable markets</span></div>
          </li>
          <li>
            <span class="feature-check fi-square">✓</span>
            <div><strong>Square POS sync</strong><br><span>Pull real sales data — fees, refunds, and discounts included</span></div>
          </li>
          <li>
            <span class="feature-check fi-design">✓</span>
            <div><strong>Custom form templates</strong><br><span>Design event forms that match exactly how you work</span></div>
          </li>
        </ul>
        <div class="starter-note">
          <span class="lock-icon">📋</span>
          <span>You're on <strong>venOS Starter</strong> — includes 1 finalized event and basic profit summary.</span>
        </div>
      </div>
      <div class="modal-divider"></div>
      <div class="modal-footer">
        <button class="cta-btn cta-primary" onclick="handleUpgradeClick()">⚡ Upgrade to Pro</button>
        <p class="price-note">Cancel anytime &nbsp;·&nbsp; No spreadsheets, no guesswork</p>
        <button class="cta-btn cta-secondary" onclick="closeUpgradeModal()">Maybe later</button>
      </div>
    </div>
  </div>

  <!-- 🟡 Welcome Beta Modal -->
  <div class="modal-overlay" id="welcomeOverlay">
    <div class="welcome-modal">

      <!-- Section 1: Welcome -->
      <div class="welcome-header">
        <div class="welcome-badge">🧪 Beta</div>
        <h2>Welcome to venOS Beta</h2>
        <p class="welcome-subtitle">You're helping us build the simplest way for event vendors to know if they actually made money.</p>
        <p class="welcome-note">This beta version is focused on one thing:<br><strong>Getting you from event → to true profit in minutes.</strong></p>
        <p class="welcome-note">Some features may evolve. Your feedback will shape the final product.</p>
      </div>

      <!-- Section 2: Steps -->
      <div class="welcome-body">
        <p class="welcome-section-label">Get started in 3 steps</p>
        <div class="welcome-steps">

          <div class="welcome-step">
            <div class="step-number">1</div>
            <h3>Add a Real Event</h3>
            <p>Use a past event from the last 30 days.</p>
            <ul>
              <li>Farmers Market</li>
              <li>Catering job</li>
              <li>School event</li>
              <li>Festival</li>
            </ul>
            <button class="btn-primary welcome-action" onclick="closeWelcomeModal(); openAddEventForUser()">Create Your First Event</button>
          </div>

          <div class="welcome-step">
            <div class="step-number">2</div>
            <h3>Connect &amp; Sync Sales</h3>
            <p>If you use Square, connect your account. venOS will pull your real sales and tax data automatically.</p>
            <p>If not, enter totals manually.</p>
            <button class="btn-secondary welcome-action" onclick="closeWelcomeModal(); navigateTo('manageSection')">Sync Sales</button>
          </div>

          <div class="welcome-step">
            <div class="step-number">3</div>
            <h3>Add Your Costs</h3>
            <p>Enter labor, supplies, event fees, permits, and food tax. Then open your Profit Summary.</p>
            <button class="btn-secondary welcome-action" onclick="closeWelcomeModal(); navigateTo('manageSection')">View Profit Summary</button>
          </div>

        </div>

        <!-- Section 3: What You'll Discover -->
        <div class="welcome-discover">
          <h3>What You'll Discover</h3>
          <ul>
            <li>✅ Your true net profit (after tax + fees)</li>
            <li>✅ Your real labor cost impact</li>
            <li>✅ Whether the event was worth it</li>
            <li>✅ Where you lost margin</li>
          </ul>
        </div>

        <!-- Section 5: Guardrails -->
        <div class="welcome-guardrails">
          <p>This is a beta version. Please report bugs. Financial calculations are based on the data entered or synced. If something looks incorrect, tell us.</p>
        </div>
      </div>

      <!-- Footer -->
      <div class="welcome-footer">
        <button class="cta-btn cta-primary" onclick="closeWelcomeModal(); openAddEventForUser()">🚀 Let's Go — Create My First Event</button>
        <button class="cta-btn cta-secondary" onclick="closeWelcomeModal()">I'll explore on my own</button>
      </div>

    </div>
  </div>

  <script>
    function toggleMobileNav() {
      document.getElementById("headerButtonsDrawer").classList.toggle("is-open");
      document.querySelector(".hamburger").classList.toggle("is-open");
    }
    function closeMobileNav() {
      document.getElementById("headerButtonsDrawer").classList.remove("is-open");
      document.querySelector(".hamburger").classList.remove("is-open");
    }
    document.addEventListener("click", function(e) {
      if (!e.target.closest(".nav-buttons")) closeMobileNav();
    });
  </script>
  <script src="/env.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
  <script src="app.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/2.4.3/purify.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
 <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script> 
 <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
 <script src="/recipes_frontend.js"></script>
</div>
</body>
</html>
