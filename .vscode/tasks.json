{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start: All Apps",
      "dependsOn": ["Start: Client", "Start: API", "Start: Marketing"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start: Client",
      "type": "npm",
      "script": "start:client",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Start: API",
      "type": "npm",
      "script": "start:api",
      "isBackground": true,
      "problemMatcher": {
        "owner": "node",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "\\[ ready \\]"
        }
      }
    },
    {
      "label": "Start: Marketing",
      "type": "npm",
      "script": "start:marketing",
      "isBackground": true,
      "problemMatcher": {
        "owner": "astro",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "astro",
          "endsPattern": "localhost"
        }
      }
    }
  ]
}
