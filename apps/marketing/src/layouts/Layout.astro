---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "venOS — Know Your Event Profit, Instantly",
  description = "venOS pulls all your event numbers together — Square fees, labor, supplies, refunds — so you finally know if your event was worth it.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://venview.io/" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content="Stop guessing. See exactly where your money went after every event." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://venview.io/" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/venview-icon-lg.png" />

    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-7658VP10C6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7658VP10C6');
    </script>
    <script is:inline src="https://t.contentsquare.net/uxa/649ea33ce46c3.js"></script>
  </head>
  <body>

    <nav>
      <div class="nav-inner">
        <a href="/" class="brand">
          <img src="/venview-icon-lg.png" alt="venOS" class="brand-icon" />
          <span class="brand-text">
            <span class="brand-name">venOS Events</span>
            <span class="brand-tag">Vendor Intelligence for Events</span>
          </span>
        </a>
        <a href="#early-access" class="nav-cta">Get Early Access</a>
      </div>
    </nav>

    <slot />

    <footer>
      <p>© 2026 venOS &nbsp;·&nbsp; <a href="/privacy">Privacy Policy</a> &nbsp;·&nbsp; <a href="mailto:hello@venos.app">hello@venos.app</a></p>
    </footer>

  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* venOS brand palette — matches the app design tokens */
    --navy:        #0B2A4A;
    --navy2:       #0A3A67;
    --green:       #19B37A;
    --green2:      #0F8F63;
    --brand-green: #2E7D32;
    --lemon:       #FFD84D;
    --lemon2:      #FFC72C;
    --cyan:        #00ABE2;
    --cyan2:       #0085b0;

    --ink:   #0B1B2B;
    --ink2:  #334559;
    --muted: #5B6B7C;
    --rule:  #dde3f0;
    --bg:    #F6FBFF;
    --white: #ffffff;
    --red:   #dc2626;

    /* The app uses a system font stack — no web fonts. */
    --font-head: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
    --font-body: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;

    --max:       1080px;
    --radius:    12px;
    --radius-lg: 16px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Nav (matches the app header) ────────────────────── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--rule);
    box-shadow: 0 2px 6px rgba(11,42,74,0.08);
    padding: 0 24px;
  }
  .nav-inner {
    max-width: var(--max);
    margin: 0 auto;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand-icon { height: 44px; width: auto; display: block; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand-name {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1.12rem;
    color: var(--brand-green);
    letter-spacing: -0.01em;
  }
  .brand-tag { font-size: 0.66rem; color: #6b7280; }
  .nav-cta {
    background: var(--cyan);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .nav-cta:hover {
    background: var(--cyan2);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0,171,226,0.28);
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 80px 24px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #e6f7f0;
    border: 1px solid rgba(25,179,122,0.35);
    color: var(--green2);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 100px;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }
  .hero-eyebrow::before {
    content: '';
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    display: inline-block;
  }

  h1 {
    font-family: var(--font-head);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--navy);
    margin-bottom: 20px;
  }
  h1 em {
    font-style: normal;
    color: var(--brand-green);
    position: relative;
  }
  h1 em::after {
    content: '';
    position: absolute;
    left: 0; bottom: -4px;
    width: 100%; height: 3px;
    background: var(--lemon);
    border-radius: 2px;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--ink2);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  /* ── Email Form ──────────────────────────────────────── */
  .capture-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .form-row {
    display: flex;
    gap: 8px;
  }
  .capture-form input[type="email"] {
    flex: 1;
    padding: 14px 18px;
    border: 1.5px solid var(--rule);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: var(--white);
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .capture-form input[type="email"]:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0,171,226,0.15);
  }
  .capture-form input[type="email"]::placeholder { color: #9ca3af; }

  .btn-primary {
    background: var(--cyan);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 24px;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    letter-spacing: -0.01em;
  }
  .btn-primary:hover {
    background: var(--cyan2);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,171,226,0.32);
  }
  .btn-primary:active { transform: translateY(0); }

  .form-note {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .form-success {
    display: none;
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #166534;
    padding: 14px 18px;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .form-error {
    display: none;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    padding: 14px 18px;
    border-radius: var(--radius);
    font-size: 0.9rem;
  }

  /* ── Hero Visual ─────────────────────────────────────── */
  .hero-visual { position: relative; }
  .dashboard-card {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: 0 20px 50px rgba(11,42,74,0.12), 0 4px 14px rgba(11,42,74,0.06);
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }
  .card-title {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .card-event {
    font-size: 0.78rem;
    background: #FFF6D6;
    color: #8a6a00;
    padding: 3px 10px;
    border-radius: 100px;
    font-weight: 600;
  }
  .metric-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }
  .metric {
    background: var(--bg);
    border-radius: 10px;
    padding: 14px;
  }
  .metric-label {
    font-size: 0.72rem;
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }
  .metric-value {
    font-family: var(--font-head);
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .metric-value.positive { color: var(--green2); }
  .metric-value.negative { color: var(--red); }
  .metric-value.neutral  { color: var(--navy); }
  .metric-delta { font-size: 0.72rem; margin-top: 2px; }
  .metric-delta.up   { color: var(--green2); }
  .metric-delta.down { color: var(--red); }

  .cost-breakdown {
    border-top: 1px solid var(--rule);
    padding-top: 16px;
  }
  .cost-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    font-size: 0.82rem;
  }
  .cost-name { color: var(--ink2); }
  .cost-amount { font-weight: 600; font-family: var(--font-head); }
  .cost-amount.bad  { color: var(--red); }
  .cost-amount.good { color: var(--green2); }

  .profit-bar-wrap {
    margin-top: 16px;
    background: #eef2f7;
    border-radius: 100px;
    height: 8px;
    overflow: hidden;
    position: relative;
  }
  .profit-bar {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--green2), var(--green));
    border-radius: 100px;
    transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .badge-float {
    position: absolute;
    top: -16px; right: -16px;
    background: var(--navy);
    color: var(--white);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 0.78rem;
    box-shadow: 0 8px 24px rgba(11,42,74,0.28);
    animation: pop-in 0.5s 0.8s both cubic-bezier(0.22,1,0.36,1);
  }
  .badge-float strong {
    display: block;
    font-family: var(--font-head);
    font-size: 1rem;
    color: var(--lemon);
  }
  @keyframes pop-in {
    from { opacity: 0; transform: scale(0.7) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ── Pain Points ─────────────────────────────────────── */
  .pain-section {
    background: var(--navy);
    padding: 72px 24px;
    margin: 60px 0;
  }
  .pain-inner { max-width: var(--max); margin: 0 auto; }

  .section-label {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green2);
    margin-bottom: 14px;
  }
  .pain-inner .section-label { color: var(--lemon); }
  .pain-inner h2 {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 48px;
    max-width: 560px;
  }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .pain-card {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.2s, background 0.2s;
  }
  .pain-card:hover {
    border-color: rgba(255,216,77,0.45);
    background: rgba(255,255,255,0.03);
  }
  .pain-icon { font-size: 1.6rem; margin-bottom: 14px; display: block; }
  .pain-card h3 {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .pain-card p { font-size: 0.88rem; color: rgba(255,255,255,0.6); line-height: 1.6; }

  /* ── Features ────────────────────────────────────────── */
  .features-section {
    max-width: var(--max);
    margin: 0 auto;
    padding: 72px 24px;
  }
  .features-section h2 {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 48px;
    max-width: 480px;
    line-height: 1.15;
    color: var(--navy);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .feature-item {
    display: flex;
    gap: 16px;
    padding: 24px;
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .feature-item:hover {
    box-shadow: 0 8px 32px rgba(11,42,74,0.10);
    transform: translateY(-2px);
  }
  .feature-dot {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: #e6f7f0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .feature-item h3 {
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
    color: var(--navy);
  }
  .feature-item p { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }

  /* ── CTA Section ─────────────────────────────────────── */
  .cta-section {
    background: linear-gradient(135deg, #0B2A4A 0%, #0A3A67 100%);
    padding: 80px 24px;
    text-align: center;
  }
  .cta-inner { max-width: 560px; margin: 0 auto; }
  .cta-section h2 {
    font-family: var(--font-head);
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .cta-section h2 span { color: var(--lemon); }
  .cta-section > .cta-inner > p {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
  }
  .cta-form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto 12px;
  }
  .cta-form input[type="email"] {
    flex: 1;
    padding: 14px 18px;
    border-radius: var(--radius);
    border: 1.5px solid rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.08);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .cta-form input[type="email"]:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0,171,226,0.25);
  }
  .cta-form input[type="email"]::placeholder { color: rgba(255,255,255,0.4); }
  .cta-note { font-size: 0.78rem; color: rgba(255,255,255,0.4); }

  /* ── Footer ──────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--rule);
    padding: 28px 24px;
    text-align: center;
  }
  footer p { font-size: 0.82rem; color: var(--muted); }
  footer a { color: var(--muted); text-decoration: underline; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; gap: 40px; padding: 48px 20px 40px; }
    .hero-visual { order: -1; }
    .badge-float { top: -10px; right: 0; }
    .pain-grid { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .form-row { flex-direction: column; }
    .cta-form { flex-direction: column; }
    .brand-tag { display: none; }
  }

  /* ── Animations ──────────────────────────────────────── */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
